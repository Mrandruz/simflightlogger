{
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/metar",
      "dest": "https://aviationweather.gov/api/data/metar"
    },
    {
      "src": "/api/taf",
      "dest": "https://aviationweather.gov/api/data/taf"
    },
    {
      "src": "/api/aviationstack/(.*)",
      "dest": "https://api.aviationstack.com/v1/$1"
    },
    {
      "src": "/api/cron-daily-report",
      "dest": "/api/cron-daily-report/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-daily-report",
      "schedule": "30 6 * * *"
    }
  ]
}
