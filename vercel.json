{
  "rewrites": [
    {
      "source": "/api/metar",
      "destination": "https://aviationweather.gov/api/data/metar"
    },
    {
      "source": "/api/taf",
      "destination": "https://aviationweather.gov/api/data/taf"
    },
    {
      "source": "/api/aviationstack/:path*",
      "destination": "https://api.aviationstack.com/v1/:path*"
    },
    {
      "source": "/api/simbrief",
      "destination": "/api/simbrief"
    },
    {
      "source": "/checklists/:file*",
      "destination": "/checklists/:file*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-daily-report",
      "schedule": "30 6 * * *"
    }
  ]
}
