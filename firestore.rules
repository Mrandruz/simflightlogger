rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Function to check if the user is the admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('(?i)and977@gmail.com') || 
        request.auth.uid == 'Mx2IJjVduddCkgs2c9dHrlAjIRT2'
      );
    }

    // Rules for the fleet collection (Velar Fleet Management)
    match /fleet/{aircraftId} {
      // Chiunque sia autenticato può leggere lo stato della flotta
      allow read: if request.auth != null;
      // Scrittura permessa solo agli amministratori o per aggiornamenti parziali degli aerei (es. ore di volo)
      allow write: if isAdmin();
    }

    // Rules for the users collection
    match /users {
      allow list: if request.auth != null;
      
      match /{userId} {
        allow get: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);

        // Sub-collections (flights, settings, operations)
        match /{allSubcollections=**} {
          allow read: if request.auth != null;
          allow write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        }
      }
    }
  }
}